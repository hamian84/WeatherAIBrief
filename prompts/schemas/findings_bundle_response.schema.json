{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "synoptic_primary_cards",
    "cross_layer_cards",
    "regional_response_cards",
    "time_change_cards"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "synoptic_primary_cards": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section", "statement", "regions", "evidence_refs"],
        "properties": {
          "section": {"type": "string", "minLength": 1},
          "statement": {"type": "string", "minLength": 1},
          "regions": {"type": "array", "items": {"type": "string"}},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "cross_layer_cards": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["card_id", "summary", "regions", "evidence_refs"],
        "properties": {
          "card_id": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "regions": {"type": "array", "items": {"type": "string"}},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "regional_response_cards": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["region", "response_summary", "evidence_refs"],
        "properties": {
          "region": {"type": "string", "minLength": 1},
          "response_summary": {"type": "string", "minLength": 1},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "time_change_cards": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["time_window", "change_summary", "evidence_refs"],
        "properties": {
          "time_window": {"type": "string", "minLength": 1},
          "change_summary": {"type": "string", "minLength": 1},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}

{
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "run_date", "allow_new_claims", "sections"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "run_date": {"type": "string", "minLength": 1},
    "allow_new_claims": {"type": "boolean"},
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_id", "title", "text", "source_card_ids", "evidence_refs"],
        "properties": {
          "section_id": {"type": "string", "enum": ["overall_summary", "synoptic_overview", "surface_overview"]},
          "title": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "source_card_ids": {"type": "array", "items": {"type": "string"}},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
          "rule_refs"
        ],
        "properties": {
          "section_id": {
            "type": "string",
            "enum": [
              "overall_summary",
              "synoptic_overview",
              "precipitation_structure",
              "surface_marine_impacts",
              "review_draft"
            ]
          },
          "title": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "evidence_summary": {"type": "string", "minLength": 1},
          "rule_summary": {"type": "string", "minLength": 1},
          "focus_regions": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "evidence_ids": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "rule_refs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "timeline_event_list.schema.json",
  "title": "시간 변화 사건 목록 스키마",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_date",
    "section_id",
    "section_title",
    "events"
  ],
  "properties": {
    "run_date": { "type": "string" },
    "section_id": { "type": "string" },
    "section_title": { "type": "string" },
    "events": {
      "type": "array",
      "items": {
        "$ref": "timeline_event.schema.json"
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "briefing_section.schema.json",
  "title": "브리핑 섹션 출력 스키마",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_date",
    "section_id",
    "title",
    "body",
    "observation_basis",
    "applied_patterns",
    "source_event_ids"
  ],
  "properties": {
    "run_date": { "type": "string" },
    "section_id": { "type": "string" },
    "title": { "type": "string" },
    "body": { "type": "string" },
    "observation_basis": {
      "type": "array",
      "items": { "type": "string" }
    },
    "applied_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_event_ids": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
